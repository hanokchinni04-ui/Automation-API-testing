              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\",  ()=> {\r",
                  "       pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test('product list exists',()=>{\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.have.property(\"products\");\r",
                  "})\r",
                  "\r",
                  "pm.test(\"Response code is 200\", ()=>{\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.responseCode).to.eql(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Check if products array is not empty\", ()=>{\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.products).to.be.an(\"array\").and.not.empty\r",
                  "})\r",
                  "\r",
                  "\r",
